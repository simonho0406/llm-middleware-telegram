# -----------------------------------------------------------------------------
# .env.example - Environment Variables
#
# Instructions:
# 1. Copy this file to a new file named .env in the same directory.
# 2. Fill in the required variables for the services you want to use.
# 3. Optional variables can be left blank if you do not use that service.
# -----------------------------------------------------------------------------

# --- Core Bot Settings (Required) ---
# Your Telegram Bot Token, obtained from @BotFather on Telegram.
# This is the only variable that is strictly required to run the bot.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# --- Ollama (Optional) ---
# The host for your local Ollama instance.
# Required if you want to use any models from Ollama.
#
# IMPORTANT: If you are running this bot inside Docker and Ollama on your
# host machine (the standard setup), you MUST use host.docker.internal.
# Do NOT use localhost.
OLLAMA_HOST=http://host.docker.internal:11434

# --- Google Gemini (Optional) ---
# Your Google Gemini API keys. You can provide multiple keys, separated by commas.
# The bot will rotate through them to manage rate limits.
# Obtain keys from Google AI Studio: https://aistudio.google.com/app/apikey
# Required to use any 'gemini/*' models.
GEMINI_API_KEYS=YOUR_GEMINI_API_KEY_1,YOUR_GEMINI_API_KEY_2

# --- OpenRouter (Optional) ---
# Your OpenRouter API key.
# Obtain from: https://openrouter.ai/keys
# Required to use any models from OpenRouter (including free ones).
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# --- HTTP Referer for OpenRouter (Optional but Recommended) ---
# Some models on OpenRouter require an HTTP Referer header.
# Set this to your project's GitHub URL or another identifying URL.
# See: https://openrouter.ai/docs#header-http-referer
OPENROUTER_HTTP_REFERER=https://github.com/your-username/your-repo-name

# -----------------------------------------------------------------------------
# --- Custom OpenAI-Compatible Providers (Optional) ---
#
# You can add any provider that is compatible with the OpenAI API.
# The variable names below (e.g., CUSTOM_PROVIDER_API_KEY) are examples.
# You can name them whatever you want, as long as they match the 'api_key'
# and 'base_url' fields you define for that provider in 'config.yaml'.
#
# See the 'providers' section in 'config.yaml' for a corresponding example.
# -----------------------------------------------------------------------------

# --- Example: Groq ---
# Obtain from: https://console.groq.com/keys
# CUSTOM_PROVIDER_API_KEY_GROQ=YOUR_GROQ_API_KEY
# CUSTOM_PROVIDER_BASE_URL_GROQ=https://api.groq.com/openai/v1

# --- Example: Anyscale ---
# CUSTOM_PROVIDER_API_KEY_ANYSCALE=YOUR_ANYSCALE_API_KEY
# CUSTOM_PROVIDER_BASE_URL_ANYSCALE=https://api.endpoints.anyscale.com/v1

# --- Google Custom Search Engine (Optional) ---
# Required if you set 'google' as the web_search provider in config.yaml.
# Obtain from Google Cloud Console.
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_CSE_ID=YOUR_GOOGLE_CSE_ID

# --- Notion Integration Token (Optional) ---
# Required if using the notion-workspace MCP server in config.yaml.
# This is the ONLY Notion variable used: the @notionhq/notion-mcp-server reads
# NOTION_TOKEN (forwarded via that server's pass_env allowlist). There is no
# NOTION_API_KEY — do not add one.
# Obtain from: https://www.notion.so/my-integrations  (token starts with "ntn_")
NOTION_TOKEN=YOUR_NOTION_TOKEN
