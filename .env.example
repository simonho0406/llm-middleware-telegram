# Telegram Bot Token (Required)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# --- Gemini API Keys ---
# Provide your Gemini API key(s) using one of the following methods:
#
# Option 1: Comma-separated list (if you have multiple keys for rotation)
# GEMINI_API_KEYS=YOUR_GEMINI_KEY_1,YOUR_GEMINI_KEY_2
#
# Option 2: Numbered keys (if you prefer separate entries)
GEMINI_API_KEY_1=YOUR_GEMINI_KEY_1
# GEMINI_API_KEY_2=YOUR_GEMINI_KEY_2
# ... add more as needed (GEMINI_API_KEY_3, etc.)
#
# Note: If both GEMINI_API_KEYS and numbered keys are provided, GEMINI_API_KEYS takes precedence.
# If neither is provided, the bot will look for a single GOOGLE_API_KEY (legacy).

# --- OpenRouter API Key ---
# Required if you want to use OpenRouter models
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# --- Custom OpenAI-Compatible Provider API Keys ---
# Add keys for providers defined in config.yaml's custom_openai_providers section.
# Use the convention PROVIDERNAME_API_KEY (all uppercase).
GROQ_API_KEY=YOUR_GROQ_API_KEY
REQUESTY_API_KEY=YOUR_REQUESTY_API_KEY # Key for Requesty provider
# ANOTHER_PROVIDER_API_KEY=YOUR_ANOTHER_PROVIDER_KEY

# --- Ollama Host ---
# Optional: Override the default Ollama host if it's not running locally
# or on the default port accessible by Docker.
# Default is http://host.docker.internal:11434 when running in Docker,
# or http://localhost:11434 if run directly.
# OLLAMA_HOST=http://your_ollama_host:11434
